export VIRTUAL_ENV="$(pwd)/venv"
export PATH="$VIRTUAL_ENV/bin:$PATH"

# Railway PostgreSQL connection
export DATABASE_URL="postgresql://postgres:yNQfzTPeqOFJsJPUPPjXkeNLIzLrfcGk@nozomi.proxy.rlwy.net:51219/railway"
export DIRECT_URL="postgresql://postgres:yNQfzTPeqOFJsJPUPPjXkeNLIzLrfcGk@nozomi.proxy.rlwy.net:51219/railway"

# Check if requirements are installed
if [ -f "$VIRTUAL_ENV/.requirements_installed" ]; then
    echo "✅ Requirements already installed"
else
    echo "📦 Installing requirements..."
    pip install -r requirements.txt > /dev/null 2>&1
    touch "$VIRTUAL_ENV/.requirements_installed"
    echo "✅ Requirements installed"
fi
