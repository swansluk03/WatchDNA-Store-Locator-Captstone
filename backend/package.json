{
  "name": "watchdna-admin-backend",
  "version": "1.0.0",
  "description": "Admin panel backend for WatchDNA Store Locator",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "create-admin": "ts-node src/scripts/create-admin.ts",
    "seed-admin": "ts-node src/scripts/seed-admin.ts",
    "import-data": "ts-node src/scripts/import-initial-data.ts",
    "import-master": "ts-node src/scripts/import-master-csv.ts",
    "export-data": "ts-node src/scripts/export-sqlite-data.ts",
    "import-postgres": "ts-node src/scripts/import-to-postgres.ts",
    "reset-db": "ts-node src/scripts/reset-database.ts",
    "normalize-countries": "ts-node src/scripts/normalize-db-countries.ts",
    "verify-countries": "ts-node src/scripts/verify-country-normalization.ts",
    "verify-countries-db": "ts-node src/scripts/verify-country-normalization.ts --db",
    "audit:location-countries": "ts-node src/scripts/audit-location-countries.ts",
    "analyze-duplicates": "ts-node src/scripts/analyze-duplicate-locations.ts",
    "cleanup-locations": "ts-node src/scripts/cleanup-locations-db.ts",
    "merge-address-dupes": "ts-node src/scripts/merge-address-duplicate-locations.ts",
    "verify-store-coordinates": "ts-node src/scripts/verify-store-coordinates.ts",
    "normalize-phones": "ts-node src/scripts/normalize-db-phones.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "admin",
    "csv",
    "validation",
    "scraper"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "i18n-iso-countries": "^7.14.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.41",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.5.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/papaparse": "^5.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  }
}
