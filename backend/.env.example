# Database (Railway PostgreSQL)
# In Railway: reference the Postgres service variable directly
DATABASE_URL="postgresql://user:password@host:port/railway"
DIRECT_URL="postgresql://user:password@host:port/railway"

# Server
PORT=3001
NODE_ENV=production

# Authentication — generate with: openssl rand -base64 32
JWT_SECRET="your-32-char-minimum-secret-here"
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-admin.railway.app,https://your-map.railway.app

# File uploads
UPLOAD_DIR=./uploads

# Python path (for scraper jobs — requires Python in runtime environment)
PYTHON_PATH=python3

# Optional: Mapbox token (for future map features)
MAPBOX_SECRET=your_mapbox_token_here
