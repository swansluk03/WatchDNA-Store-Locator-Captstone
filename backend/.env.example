# Copy to .env and fill in values.

# Database
DATABASE_URL=

# Auth
JWT_SECRET=

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173

# Upload root: absolute path on disk for CSVs, store-images/, scraped/, etc.
# Local dev: omit to use <backend>/uploads.
# Railway: mount a Volume on the backend service, then either:
#   - leave UPLOAD_DIR unset (uses RAILWAY_VOLUME_MOUNT_PATH from Railway), or
#   - set UPLOAD_DIR to the same path as the volume mount (e.g. /data/uploads).
# UPLOAD_DIR=
