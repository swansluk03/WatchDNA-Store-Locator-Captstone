# Copy to .env and fill in values.

# Database
DATABASE_URL=

# Auth
JWT_SECRET=

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173

# Upload root: absolute path on disk for CSVs, store-images/, scraped/, etc.
# Local dev: omit to use <backend>/uploads.
# Railway: mount a Volume on the backend service, then either:
#   - leave UPLOAD_DIR unset (uses RAILWAY_VOLUME_MOUNT_PATH from Railway), or
#   - set UPLOAD_DIR to the same path as the volume mount (e.g. /data/uploads).
# UPLOAD_DIR=

# Optional: store premium location images in Shopify Admin → Content → Files (CDN URLs in DB).
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Dev Dashboard: client_credentials (token auto-refreshed in process memory ~24h).
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
# Optional override (static token; skips client credentials), e.g. local dev:
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...
# SHOPIFY_ADMIN_API_VERSION=2025-10
